{
  "name": "next-js-boilerplate",
  "author": "Ixartz (https://github.com/ixartz)",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build:next": "next build --webpack",
    "build-local": "run-p db-server:memory build:next --race",
    "build": "run-s db:migrate build:next",
    "start": "next start",
    "build-stats": "cross-env ANALYZE=true npm run build",
    "clean": "rimraf .next out coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check:types": "tsc --noEmit --pretty",
    "db:push": "drizzle-kit push",
    "check:deps": "knip",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "db-server:file": "pglite-server --db=local.db --run 'npm run db:migrate'",
    "db-server:memory": "pglite-server --run 'npm run db:migrate'",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed-superadmin": "node --env-file=.env.local scripts/seed-superadmin.mjs",
    "db:seed-modules": "NODE_ENV=development node --env-file=.env.local -r esbuild-register scripts/seed-treatment-modules.ts",
    "db:seed-templates": "NODE_ENV=development node --env-file=.env.local -r esbuild-register scripts/seed-templates.ts",
    "db:seed-prompts": "NODE_ENV=development node --env-file=.env.local -r esbuild-register scripts/seed-system-prompts.ts",
    "db:seed-therapist-prompts": "NODE_ENV=development node --env-file=.env.local -r esbuild-register scripts/seed-therapist-prompts.ts",
    "db:delete-therapist-prompts": "NODE_ENV=development node --env-file=.env.local -r esbuild-register scripts/delete-therapist-prompts.ts",
    "storybook": "storybook dev -p 6006",
    "storybook:test": "vitest run --config .storybook/vitest.config.mts",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@deepgram/sdk": "^4.11.2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google-cloud/run": "^3.0.1",
    "@google-cloud/storage": "^7.17.3",
    "@hookform/resolvers": "^5.2.2",
    "@t3-oss/env-nextjs": "^0.13.8",
    "@tailwindcss/typography": "^0.5.0-alpha.3",
    "@tiptap/extension-highlight": "^3.15.1",
    "@tiptap/extension-placeholder": "^3.15.1",
    "@tiptap/extension-text-align": "^3.15.1",
    "@tiptap/extension-underline": "^3.15.1",
    "@tiptap/react": "^3.15.1",
    "@tiptap/starter-kit": "^3.15.1",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@wavesurfer/react": "^1.0.12",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.44.7",
    "firebase": "^11.2.0",
    "firebase-admin": "^13.0.1",
    "google-auth-library": "^9.15.1",
    "jsonrepair": "^3.13.1",
    "lightningcss": "^1.30.2",
    "lucide-react": "^0.548.0",
    "marked": "^17.0.1",
    "next": "^16.0.0",
    "openai": "^6.7.0",
    "pg": "^8.16.3",
    "posthog-js": "^1.281.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.0",
    "react-day-picker": "^9.13.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.65.0",
    "react-hot-toast": "^2.6.0",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^6.1.0",
    "@chromatic-com/playwright": "^0.12.7",
    "@electric-sql/pglite-socket": "^0.0.16",
    "@eslint-react/eslint-plugin": "^2.2.4",
    "@faker-js/faker": "^10.1.0",
    "@next/bundle-analyzer": "^16.0.0",
    "@next/eslint-plugin-next": "^16.0.0",
    "@playwright/test": "^1.56.1",
    "@storybook/addon-a11y": "^10.0.0",
    "@storybook/addon-docs": "^10.0.0",
    "@storybook/addon-vitest": "^10.0.0",
    "@storybook/nextjs-vite": "^10.0.0",
    "@tailwindcss/postcss": "^4.1.16",
    "@types/marked": "^5.0.2",
    "@types/node": "^24.9.1",
    "@types/pg": "^8.15.6",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.0",
    "@vitest/browser": "^4.0.4",
    "@vitest/browser-playwright": "^4.0.4",
    "@vitest/coverage-v8": "^4.0.4",
    "babel-plugin-react-compiler": "^1.0.0",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^10.0.0",
    "drizzle-kit": "^0.31.6",
    "eslint": "^9.38.0",
    "eslint-plugin-format": "^1.0.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-playwright": "^2.2.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "eslint-plugin-storybook": "^10.0.0",
    "eslint-plugin-tailwindcss": "^4.0.0-beta.0",
    "knip": "^5.66.4",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.6",
    "postcss-load-config": "^6.0.1",
    "rimraf": "^6.0.1",
    "storybook": "^10.0.0",
    "tailwindcss": "^4.1.16",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.4",
    "vitest-browser-react": "^2.0.2"
  }
}
